{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["bun"]
  },
  "include": [
    "packages/pi-engage/src/**/*.ts",
    "packages/pi-engage/test/**/*.ts",
    "packages/pi-exploitsearch/src/**/*.ts",
    "packages/pi-exploitsearch/test/**/*.ts",
    "packages/pi-casefile/src/**/*.ts",
    "packages/pi-casefile/test/**/*.ts",
    "packages/pi-lookup/src/**/*.ts",
    "packages/pi-lookup/test/**/*.ts",
    "packages/pi-xtodo/index.ts",
    "packages/pi-xtodo/test/**/*.ts"
  ]
}
