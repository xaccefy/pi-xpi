{
  "name": "@xaccefy/pi-xpi",
  "version": "0.1.3",
  "description": "XPI — offensive security tools for Pi Agent. Casefile tracking, web search, library docs, exploit technique search, code intelligence, todo tracking.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "xpi",
    "security",
    "bug-bounty",
    "pentest",
    "ctf",
    "exploit",
    "web-search"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x4cc3/pi-xpi.git"
  },
  "homepage": "https://github.com/x4cc3/pi-xpi#readme",
  "bugs": {
    "url": "https://github.com/x4cc3/pi-xpi/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "prompts/",
    "agents/",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@xaccefy/pi-casefile": "*",
    "@xaccefy/pi-exploitsearch": "*",
    "@xaccefy/pi-lookup": "*",
    "@xaccefy/pi-codeintel": "*",
    "@xaccefy/pi-xtodo": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "scripts": {
    "test": "node --test packages/pi-casefile/test/ledger.test.ts packages/pi-lookup/test/websearch.test.ts packages/pi-codeintel/test/codeintel.test.ts packages/pi-xtodo/test/todo.test.ts",
    "test:casefile": "node --test packages/pi-casefile/test/ledger.test.ts",
    "test:lookup": "node --test packages/pi-lookup/test/websearch.test.ts",
    "test:codeintel": "node --test packages/pi-codeintel/test/codeintel.test.ts",
    "test:xtodo": "node --test packages/pi-xtodo/test/todo.test.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "postinstall": "bash install.sh",
    "version:patch": "npm version patch -ws --no-git-tag-version && npm version patch --no-git-tag-version && node scripts/sync-versions.js",
    "version:minor": "npm version minor -ws --no-git-tag-version && npm version minor --no-git-tag-version && node scripts/sync-versions.js",
    "version:major": "npm version major -ws --no-git-tag-version && npm version major --no-git-tag-version && node scripts/sync-versions.js",
    "publish:all": "npm publish -ws --access public && npm publish --access public",
    "publish:dry": "npm publish -ws --access public --dry-run",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  }
}
