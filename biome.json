{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "defaultBranch": "main" },
  "formatter": { "indentStyle": "space", "indentWidth": 2, "lineEnding": "lf", "lineWidth": 100 },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": { "noUnusedVariables": "error", "noUnusedImports": "error" },
      "suspicious": { "noConsole": "warn", "noExplicitAny": "warn" },
      "style": { "noNonNullAssertion": "warn" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double", "trailingCommas": "all" } }
}
