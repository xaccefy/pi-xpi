{
  "name": "@xaccefy/pi-engage",
  "version": "0.2.8",
  "description": "Authenticated-session manager for Pi Agent — store and resolve cookie, OAuth client-credentials, and mTLS auth for authorized pentest targets",
  "keywords": [
    "pi-package",
    "pi-extension",
    "xpi",
    "security",
    "pentest",
    "auth",
    "oauth",
    "mtls"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x4cc3/pi-xpi.git",
    "directory": "packages/pi-engage"
  },
  "homepage": "https://github.com/x4cc3/pi-xpi/tree/main/packages/pi-engage#readme",
  "bugs": {
    "url": "https://github.com/x4cc3/pi-xpi/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src/index.ts",
    "src/engage.ts",
    "src/credential.ts",
    "src/store.ts",
    "src/types.ts",
    "README.md",
    "LICENSE"
  ],
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.34"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
